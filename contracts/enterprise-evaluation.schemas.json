{"$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://ara.example/spec/contracts/enterprise-evaluation.schemas.json","title":"ARA enterprise evaluation schema","$defs":{"id":{"type":"string","minLength":1,"maxLength":200},"digest":{"type":"string","pattern":"^sha256:[0-9a-f]{64}$"},"semver":{"type":"string","pattern":"^[0-9]+\.[0-9]+\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"},"instant":{"type":"string","format":"date-time"},"money":{"type":"object","additionalProperties":false,"required":["amount","currency"],"properties":{"amount":{"type":"string","pattern":"^-?[0-9]+(?:\.[0-9]{1,6})?$"},"currency":{"type":"string","pattern":"^[A-Z]{3}$"}}},"subject":{"type":"object","additionalProperties":false,"required":["kind","versionRef"],"properties":{"kind":{"enum":["agent","workflow","execution_plan"]},"versionRef":{"$ref":"#/$defs/id"}}},"evaluation-result":{"type":"object","additionalProperties":false,"required":["schemaVersion","evaluationResultId","subjectRef","evaluationSuiteVersionRef","status","metrics","hardGates","completedAt"],"properties":{"schemaVersion":{"const":"1.0.0"},"evaluationResultId":{"$ref":"#/$defs/id"},"subjectRef":{"$ref":"#/$defs/id"},"evaluationSuiteVersionRef":{"$ref":"#/$defs/id"},"status":{"enum":["passed","failed","inconclusive"]},"metrics":{"type":"object","additionalProperties":{"type":["number","string","boolean","null"]}},"hardGates":{"type":"array","items":{"type":"object","additionalProperties":false,"required":["gateId","status"],"properties":{"gateId":{"$ref":"#/$defs/id"},"status":{"enum":["passed","failed","not_applicable","inconclusive"]},"evidenceRef":{"$ref":"#/$defs/id"},"reason":{"type":"string"}}}},"evidenceBundleRef":{"$ref":"#/$defs/id"},"completedAt":{"$ref":"#/$defs/instant"}}}}}
