{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ara.dev/contracts/1.0/schemas/deployment-snapshot.schema.json",
  "title": "ARA DeploymentSnapshot",
  "type": "object",
  "required": [
    "contractVersion",
    "deploymentSnapshotId",
    "environment",
    "resourceVersions",
    "packageInstallations",
    "contractVersions",
    "digest",
    "signatureRef"
  ],
  "properties": {
    "contractVersion": { "const": "1.0.0" },
    "deploymentSnapshotId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "environment": { "type": "string", "minLength": 1 },
    "resourceVersions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "ref", "digest"],
        "properties": {
          "kind": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
          "ref": { "type": "string", "minLength": 1 },
          "digest": { "$ref": "common.schema.json#/$defs/ContentDigest" }
        },
        "additionalProperties": false
      }
    },
    "packageInstallations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["installationId", "revision", "digest", "packageLockDigest"],
        "properties": {
          "installationId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
          "revision": { "type": "integer", "minimum": 1 },
          "digest": { "$ref": "common.schema.json#/$defs/ContentDigest" },
          "packageLockDigest": { "$ref": "common.schema.json#/$defs/ContentDigest" }
        },
        "additionalProperties": false
      }
    },
    "contractVersions": {
      "type": "object",
      "required": ["runtime", "events", "manifests"],
      "properties": {
        "runtime": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "events": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "manifests": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "apiProfile": { "type": "string" },
        "eventProfile": { "type": "string" },
        "mcpProfile": { "type": "string" },
        "a2aProfile": { "type": "string" },
        "durableBackendProfile": { "type": "string" }
      },
      "additionalProperties": false
    },
    "validFrom": { "$ref": "common.schema.json#/$defs/Instant" },
    "expiresAt": { "$ref": "common.schema.json#/$defs/Instant" },
    "digest": { "$ref": "common.schema.json#/$defs/ContentDigest" },
    "signatureRef": { "type": "string", "minLength": 1 },
    "provenanceRef": { "type": "string", "minLength": 1 },
    "extensions": { "$ref": "common.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}