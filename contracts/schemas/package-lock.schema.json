{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ara.dev/contracts/1.0/schemas/package-lock.schema.json",
  "title": "ARA PackageLock",
  "type": "object",
  "required": [
    "contractVersion",
    "packageLockId",
    "rootPackageRelease",
    "resolved",
    "resolverRef",
    "generatedAt",
    "lockDigest"
  ],
  "properties": {
    "contractVersion": { "const": "1.0.0" },
    "packageLockId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "rootPackageRelease": { "type": "string", "minLength": 1 },
    "resolved": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["package", "version", "digest"],
        "properties": {
          "package": { "type": "string", "minLength": 1 },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][A-Za-z0-9.-]+)?$" },
          "digest": { "$ref": "common.schema.json#/$defs/ContentDigest" },
          "sourceRegistry": { "type": "string" },
          "signatureRef": { "type": "string" },
          "sbomDigest": { "$ref": "common.schema.json#/$defs/ContentDigest" }
        },
        "additionalProperties": false
      }
    },
    "resolverRef": { "type": "string", "minLength": 1 },
    "generatedAt": { "$ref": "common.schema.json#/$defs/Instant" },
    "lockDigest": { "$ref": "common.schema.json#/$defs/ContentDigest" },
    "extensions": { "$ref": "common.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}