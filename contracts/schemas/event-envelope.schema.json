{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ara.dev/contracts/1.0/schemas/event-envelope.schema.json",
  "title": "ARA canonical event envelope",
  "type": "object",
  "required": [
    "contractVersion",
    "eventId",
    "eventType",
    "schemaVersion",
    "occurredAt",
    "recordedAt",
    "tenantId",
    "workspaceId",
    "region",
    "aggregateType",
    "aggregateId",
    "aggregateVersion",
    "rootRunId",
    "runId",
    "runSequence",
    "actor",
    "correlationId",
    "dataClassification",
    "payloadDigest"
  ],
  "properties": {
    "contractVersion": { "const": "1.0.0" },
    "eventId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "eventType": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
    "schemaVersion": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "occurredAt": { "$ref": "common.schema.json#/$defs/Instant" },
    "recordedAt": { "$ref": "common.schema.json#/$defs/Instant" },
    "tenantId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "workspaceId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "region": { "type": "string", "minLength": 1 },
    "aggregateType": { "type": "string", "pattern": "^[a-z][a-z0-9_.-]*$" },
    "aggregateId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "aggregateVersion": { "type": "integer", "minimum": 0 },
    "rootRunId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "parentRunId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "runId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "runSequence": { "type": "integer", "minimum": 1 },
    "activityId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "activityRunId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "activityAttemptId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "branchId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "iterationId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "effectId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "invocationId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "workerLeaseId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "actor": { "$ref": "common.schema.json#/$defs/ActorIdentity" },
    "correlationId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "causationId": { "$ref": "common.schema.json#/$defs/OpaqueId" },
    "traceId": { "type": "string", "pattern": "^[A-Fa-f0-9]{32}$" },
    "dataClassification": { "type": "string", "minLength": 1 },
    "payloadDigest": { "$ref": "common.schema.json#/$defs/ContentDigest" },
    "payloadRef": { "type": "string", "minLength": 1 },
    "retentionPolicyRef": { "type": "string", "minLength": 1 },
    "extensions": { "$ref": "common.schema.json#/$defs/Extensions" }
  },
  "additionalProperties": false
}